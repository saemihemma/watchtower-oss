{
  "name": "@watchtower-bench/core",
  "version": "1.0.0",
  "description": "Core engine for Watchtower — a local benchmark for markdown skill libraries. Source resolution, scoring, IRT calibration, and statistical analysis.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "Sæmundur",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/saemihemma/watchtower.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/saemihemma/watchtower#readme",
  "bugs": {
    "url": "https://github.com/saemihemma/watchtower/issues"
  },
  "keywords": [
    "benchmark",
    "skill-library",
    "markdown",
    "evaluation",
    "irt",
    "psychometrics"
  ],
  "dependencies": {
    "minimatch": "^10.0.3",
    "uuid": "^13.0.0"
  }
}
